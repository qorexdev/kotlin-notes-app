<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.editor.EditorFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/title"
            android:inputType="textCapSentences"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:background="@android:color/transparent"
            android:padding="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="?android:attr/listDivider" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="top"
            android:hint="@string/note_content"
            android:inputType="textMultiLine|textCapSentences"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:background="@android:color/transparent"
            android:padding="8dp"
            android:minHeight="200dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/color_label"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/color_default"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@color/note_default"
                android:contentDescription="@string/color_default"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/color_red"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@color/note_red"
                android:contentDescription="@string/color_red"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/color_orange"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@color/note_orange"
                android:contentDescription="@string/color_orange"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/color_yellow"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@color/note_yellow"
                android:contentDescription="@string/color_yellow"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/color_green"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@color/note_green"
                android:contentDescription="@string/color_green"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/color_blue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@color/note_blue"
                android:contentDescription="@string/color_blue"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/color_purple"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@color/note_purple"
                android:contentDescription="@string/color_purple"
                android:scaleType="center" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
